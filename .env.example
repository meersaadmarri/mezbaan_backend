APP_NAME=Mezban
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOUR-SERVICE.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stderr
LOG_LEVEL=info

# ── Database (Railway MySQL plugin — reference variables in Railway dashboard) ──
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
# Or single URL (Laravel reads DB_URL for mysql driver):
# DB_URL=mysql://user:pass@host:3306/mezban_db

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

BROADCAST_CONNECTION=log
MAIL_MAILER=log

# Firebase push (optional — paste JSON paths or upload via Railway volume)
FIREBASE_CREDENTIALS_F0641="${APP_STORAGE_PATH}/app/firebase/mezbaan-f0641.json"
FIREBASE_CREDENTIALS_5CA22="${APP_STORAGE_PATH}/app/firebase/mezbaan-5ca22.json"
